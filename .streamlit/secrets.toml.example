# Streamlit Cloud Secrets — TOML format
# Copy this to your Streamlit Cloud app: Settings -> Secrets.
# Do NOT commit real values to git.
#
# All values below are read by config.py through st.secrets with safe
# fallbacks to environment variables / .env when running locally.

# ---------------------------------------------------------------------------
# Meta (Facebook) Ads Manager API
# ---------------------------------------------------------------------------
META_ACCESS_TOKEN = "EAAXn3YbF..."
META_API_VERSION = "v21.0"

# Optional: App credentials for refreshing long-lived tokens.
# META_APP_ID = "1234567890"
# META_APP_SECRET = "abcdef0123456789abcdef0123456789"
# An ``ads_manager_secret`` env var is also accepted as a fallback name
# for ``META_APP_SECRET`` (handy when the secret is provisioned under
# that name by your secrets manager).

# Ad account IDs — TOML array (Streamlit native list format).
META_AD_ACCOUNT_IDS = [
  "act_123456789",
  "act_987654321",
]

# ---------------------------------------------------------------------------
# Google Sheets — spreadsheets to auto-load
# ---------------------------------------------------------------------------
GOOGLE_SPREADSHEET_NAMES = [
  "Sheet Name 1",
  "Sheet Name 2",
]
GOOGLE_HEADER_ROW = "3"

# ---------------------------------------------------------------------------
# Google Service Account credentials
# ---------------------------------------------------------------------------
# Recommended for Streamlit Cloud: paste the FULL JSON key as a single
# string. Use triple quotes so newlines inside the private key are
# preserved verbatim.
GOOGLE_CREDENTIALS_JSON = """
{
  "type": "service_account",
  "project_id": "your-project-id",
  "private_key_id": "key-id",
  "private_key": "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n",
  "client_email": "your-sa@your-project.iam.gserviceaccount.com",
  "client_id": "123456789",
  "auth_uri": "https://accounts.google.com/o/oauth2/auth",
  "token_uri": "https://oauth2.googleapis.com/token",
  "auth_provider_x509_cert_url": "https://www.googleapis.com/oauth2/v1/certs",
  "client_x509_cert_url": "https://www.googleapis.com/robot/v1/metadata/x509/your-sa%40your-project.iam.gserviceaccount.com",
  "universe_domain": "googleapis.com"
}
"""

# Alternative format (still supported): a TOML table named
# [google_credentials]. Either GOOGLE_CREDENTIALS_JSON or this table
# works — provide exactly one.
#
# [google_credentials]
# type = "service_account"
# project_id = "your-project-id"
# private_key_id = "key-id"
# private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# client_email = "your-sa@your-project.iam.gserviceaccount.com"
# client_id = "123456789"
# auth_uri = "https://accounts.google.com/o/oauth2/auth"
# token_uri = "https://oauth2.googleapis.com/token"
# auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
# client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/your-sa%40your-project.iam.gserviceaccount.com"
# universe_domain = "googleapis.com"
