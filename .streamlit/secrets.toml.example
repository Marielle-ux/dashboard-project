# =============================================================
# Streamlit Cloud Secrets
# Copy this to Settings → Secrets in your Streamlit Cloud app.
# Do NOT commit real values to git.
# =============================================================

# Meta Ads API
META_ACCESS_TOKEN = "EAAXn3YbF..."
META_API_VERSION = "v21.0"

# Ad account IDs — TOML array format:
META_AD_ACCOUNT_IDS = [
  "act_123456789",
  "act_987654321",
]

# Google Sheets — TOML array format:
GOOGLE_SPREADSHEET_NAMES = [
  "Sheet Name 1",
  "Sheet Name 2",
]
GOOGLE_HEADER_ROW = "3"

# Sync interval in minutes
SYNC_INTERVAL_MINUTES = "15"

# =============================================================
# Google Service Account credentials
# Choose ONE of these two methods:
# =============================================================

# --- Method 1: JSON string (simpler) ---
# Paste the entire JSON key file contents as a single string:
GOOGLE_CREDENTIALS_JSON = '{"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"sa@project.iam.gserviceaccount.com","client_id":"123","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/robot/v1/metadata/x509/sa%40project.iam.gserviceaccount.com","universe_domain":"googleapis.com"}'

# --- Method 2: TOML section (alternative) ---
# Uncomment and fill in each field:
# [google_credentials]
# type = "service_account"
# project_id = "your-project-id"
# private_key_id = "key-id"
# private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# client_email = "your-sa@your-project.iam.gserviceaccount.com"
# client_id = "123456789"
# auth_uri = "https://accounts.google.com/o/oauth2/auth"
# token_uri = "https://oauth2.googleapis.com/token"
# auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
# client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/your-sa%40your-project.iam.gserviceaccount.com"
# universe_domain = "googleapis.com"
