# Meta (Facebook) Ads Manager API credentials
# Get these from https://developers.facebook.com/apps/
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
# Comma-separated list of ad account IDs (with or without act_ prefix)
META_AD_ACCOUNT_IDS=act_123456789,act_987654321
# Legacy single-account fallback (used if META_AD_ACCOUNT_IDS is not set)
# META_AD_ACCOUNT_ID=
META_API_VERSION=v21.0

# Google Sheets credentials
# Path to your Google service account JSON key file
GOOGLE_CREDENTIALS_FILE=google_credentials.json
# Comma-separated list of spreadsheet names to auto-load
GOOGLE_SPREADSHEET_NAMES=Sheet Name 1,Sheet Name 2

# Database
DATABASE_PATH=dashboard.db

# Sync interval in minutes
SYNC_INTERVAL_MINUTES=30
