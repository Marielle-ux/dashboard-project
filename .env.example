# ============================================================
# .env — шаблон конфигурации для Marketing Analytics Dashboard
# ============================================================
# Скопируйте этот файл:  cp .env.example .env
# Заполните значения и перезапустите приложение.

# ----------------------------------------------------------
# Meta (Facebook) Ads Manager API
# Получите токен: https://developers.facebook.com/tools/explorer/
# ----------------------------------------------------------
META_ACCESS_TOKEN=EAAXn3YbFKBY...your-token-here...
META_AD_ACCOUNT_IDS=act_844229314275496,act_2342025859327675
META_API_VERSION=v21.0

# (Необязательно) App credentials для long-lived токенов
# META_APP_ID=
# META_APP_SECRET=

# ----------------------------------------------------------
# Google Sheets
# ----------------------------------------------------------
# Путь к JSON-ключу сервисного аккаунта Google
GOOGLE_CREDENTIALS_FILE=google_credentials.json

# Названия таблиц для автоматической загрузки (через запятую)
GOOGLE_SPREADSHEET_NAMES=МАРИ БРОНЬ Атырау Май 2026,МАРИ БРОНЬ АКТОБЕ МАЙ 2026 МАРИ,Караганда БРОНЬ  Май 2026

# Номер строки с заголовками (по умолчанию 3)
GOOGLE_HEADER_ROW=3

# ----------------------------------------------------------
# База данных
# ----------------------------------------------------------
DATABASE_PATH=dashboard.db

# ----------------------------------------------------------
# Автосинхронизация (интервал в минутах)
# ----------------------------------------------------------
SYNC_INTERVAL_MINUTES=15
